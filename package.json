{
  "name": "make-local-pizza-recipe-agent",
  "version": "0.5.0",
  "private": true,
  "description": "ローカル/旬の食材を活かしたピザレシピを提案する AI エージェント",
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "pnpm": ">=10.0.0 <11.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "prebuild": "node --experimental-strip-types --no-warnings=ExperimentalWarning scripts/build-ingredient-data.ts",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "vitest run --config vitest.config.rules.ts",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=./.cache/ms-playwright playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:ui": "PLAYWRIGHT_BROWSERS_PATH=./.cache/ms-playwright playwright test --config tests/e2e/playwright.config.ts --ui",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build:data": "node --experimental-strip-types --no-warnings=ExperimentalWarning scripts/build-ingredient-data.ts",
    "seed:furusato": "cd agent && FIRESTORE_EMULATOR_HOST=localhost:8080 MLPR_GOOGLE_CLOUD_PROJECT=mlpr-local uv run python scripts/refresh_furusato_cache.py",
    "seed:furusato:dry": "cd agent && uv run python scripts/refresh_furusato_cache.py --dry-run --in-memory"
  },
  "dependencies": {
    "@google-cloud/opentelemetry-cloud-trace-exporter": "^3.0.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "firebase": "^12.13.0",
    "google-auth-library": "^10.6.2",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-import": "^2.32.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
