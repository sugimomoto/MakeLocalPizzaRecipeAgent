{
  "name": "make-local-pizza-recipe-agent",
  "version": "0.1.0",
  "private": true,
  "description": "ローカル/旬の食材を活かしたピザレシピを提案する AI エージェント",
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "pnpm": ">=10.0.0 <11.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "prebuild": "node scripts/build-ingredient-data.mjs",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build:data": "node scripts/build-ingredient-data.mjs"
  }
}
