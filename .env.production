# =============================================================================
# .env.production — Cloud Run image build 時に bundle に焼き込む env
# =============================================================================
# Next.js は `pnpm build` 実行時に .env.production を NODE_ENV=production
# として読み込み、NEXT_PUBLIC_* な値を client bundle にインライン化する。
#
# 重要:
# - NEXT_PUBLIC_FIREBASE_* は **build 時** に bundle に焼き込まれる。
#   Cloud Run の runtime env では書き換えできない (build 後は固定)。
# - Firebase Web config (apiKey 含む) は **公開を前提とした識別子** であり、
#   秘密情報ではない。Auth / Firestore は Security Rules + ID Token で守る。
# - サーバ side のみで使う env (AGENT_BASE_URL 等) は Cloud Run runtime env
#   で渡す (Terraform / gcloud run services update)。
# =============================================================================

NEXT_PUBLIC_APP_NAME="ふるさとピザ帳"
NEXT_PUBLIC_APP_VERSION=0.7.0

# 2026-06: 本番運用 URL を独自ドメイン furusato-pizza.jp に切替。
# app/layout.tsx の metadataBase 等で OGP / Twitter Card の絶対 URL 生成に使われる。
NEXT_PUBLIC_APP_URL=https://furusato-pizza.jp

# Firebase Web config (本番プロジェクト)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=makelocalpizzarecipeagent
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyCUyc-kVYtAi03qlORQAsPgMUPDN0lerc4
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=makelocalpizzarecipeagent.firebaseapp.com
NEXT_PUBLIC_FIREBASE_APP_ID=1:343527548585:web:17422d21e9465e53746bb8
# 2024-10 以降の新形式バケット (旧 *.appspot.com → *.firebasestorage.app)。
# 明示しないと client.ts が projectId から推測して存在しないバケットを叩き、
# Storage upload が無限 hang する (例: フィードバック画面の写真アップロード)。
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=makelocalpizzarecipeagent.firebasestorage.app

# 本番では Emulator を使わない
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false

# 楽天ふるさと納税セクションを有効化
NEXT_PUBLIC_FURUSATO_INTEGRATION=on

# Next.js telemetry を切る
NEXT_TELEMETRY_DISABLED=1

# Google Analytics 4 (本番のみ有効化)
# Stream: ふるさとピザ帳 / https://furusato-pizza.jp / Stream ID: 15014650460
# `@next/third-parties/google` の <GoogleAnalytics /> に渡され、本番 bundle に焼き込まれる。
# 計測 ID は GA4 のプロパティ識別子であり秘密ではない (gtag.js は公開スクリプト)。
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-6E5PHQ544B
