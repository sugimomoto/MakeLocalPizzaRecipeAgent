          }
        },
        {
          "name": "寄附額 安い順",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/IchibaItem/Search/20260401?applicationId={{APPLICATION_ID}}&keyword=ふるさと納税 チーズ&sort=%2BitemPrice&hits=10&format=json&field=0",
