              "raw": "{{BASE_URL}}/IchibaItem/Search/20260401?applicationId={{APPLICATION_ID}}&keyword=ふるさと納税 ホタテ&availability=1&imageFlag=1&hits=10&format=json",
              "host": ["{{BASE_URL}}"],
              "path": ["IchibaItem", "Search", "20260401"],
              "query": [
                { "key": "applicationId", "value": "{{APPLICATION_ID}}" },
                { "key": "keyword", "value": "ふるさと納税 ホタテ" },
