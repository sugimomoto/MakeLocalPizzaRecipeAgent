              "query": [
                { "key": "applicationId", "value": "{{APPLICATION_ID}}" },
                { "key": "keyword", "value": "ふるさと納税 京都 抹茶" },
                { "key": "hits", "value": "10" },
                { "key": "format", "value": "json" },
                { "key": "field", "value": "0" },
                { "key": "availability", "value": "1" },
                { "key": "imageFlag", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "ふるさと納税 + 北海道 帆立",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/IchibaItem/Search/20260401?applicationId={{APPLICATION_ID}}&keyword=ふるさと納税 北海道 帆立&hits=10&format=json&field=0&availability=1&imageFlag=1",
              "host": ["{{BASE_URL}}"],
              "path": ["IchibaItem", "Search", "20260401"],
              "query": [
                { "key": "applicationId", "value": "{{APPLICATION_ID}}" },
                { "key": "keyword", "value": "ふるさと納税 北海道 帆立" },
                { "key": "hits", "value": "10" },
                { "key": "format", "value": "json" },
                { "key": "field", "value": "0" },
                { "key": "availability", "value": "1" },
                { "key": "imageFlag", "value": "1" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. genreId の罠（実証）",
      "description": "新エンドポイントでは `genreId=561023`（ふるさと納税）を指定すると count=0 が返る。実証ベースで残しておく検証用フォルダ。",
      "item": [
        {
          "name": "❌ genreId=561023 を指定 → count=0",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/IchibaItem/Search/20260401?applicationId={{APPLICATION_ID}}&keyword=牡蠣&genreId=561023&hits=3&format=json",
              "host": ["{{BASE_URL}}"],
              "path": ["IchibaItem", "Search", "20260401"],
              "query": [
                { "key": "applicationId", "value": "{{APPLICATION_ID}}" },
                { "key": "keyword", "value": "牡蠣" },
                { "key": "genreId", "value": "561023" },
                { "key": "hits", "value": "3" },
                { "key": "format", "value": "json" }
              ]
            },
            "description": "**期待**: HTTP 200 だが `count: 0` が返る。新エンドポイントでは genreId=561023 が機能しない。実証済み（2026-05）。"
          }
        },
