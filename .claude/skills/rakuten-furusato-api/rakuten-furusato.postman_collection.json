              "host": ["{{BASE_URL}}"],
              "path": ["IchibaItem", "Search", "20260401"],
              "query": [
                { "key": "applicationId", "value": "{{APPLICATION_ID}}" },
                { "key": "keyword", "value": "ふるさと納税 牡蠣" },
                { "key": "minPrice", "value": "10000" },
                { "key": "maxPrice", "value": "30000" },
                { "key": "hits", "value": "10" },
                { "key": "format", "value": "json" },
                { "key": "field", "value": "0" },
                { "key": "availability", "value": "1" }
              ]
            },
            "description": "minPrice / maxPrice で寄附額の範囲指定。本プロジェクトの `max_donation_yen` 引数に対応。"
          }
        },
        {
          "name": "部分一致モード（field=0）",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/IchibaItem/Search/20260401?applicationId={{APPLICATION_ID}}&keyword=ふるさと納税 せり&field=0&hits=10&format=json",
              "host": ["{{BASE_URL}}"],
              "path": ["IchibaItem", "Search", "20260401"],
              "query": [
                { "key": "applicationId", "value": "{{APPLICATION_ID}}" },
                { "key": "keyword", "value": "ふるさと納税 せり" },
                { "key": "field", "value": "0" },
                { "key": "hits", "value": "10" },
                { "key": "format", "value": "json" }
              ]
            },
            "description": "**`field` の既定は 1（厳密）**。短いキーワードでは既定値で 0 件になりがち。`field=0` で部分一致。次の `field=1` リクエストとヒット数を比較。"
          }
        },
        {
          "name": "厳密一致モード（field=1、既定）",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/IchibaItem/Search/20260401?applicationId={{APPLICATION_ID}}&keyword=ふるさと納税 せり&field=1&hits=10&format=json",
              "host": ["{{BASE_URL}}"],
              "path": ["IchibaItem", "Search", "20260401"],
              "query": [
                { "key": "applicationId", "value": "{{APPLICATION_ID}}" },
