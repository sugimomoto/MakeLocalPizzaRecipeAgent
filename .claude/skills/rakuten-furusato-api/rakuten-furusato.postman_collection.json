        {
          "name": "✅ keyword に「ふるさと納税」を AND 結合（推奨）",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/IchibaItem/Search/20260401?applicationId={{APPLICATION_ID}}&keyword=ふるさと納税 牡蠣&hits=3&format=json&field=0",
              "host": ["{{BASE_URL}}"],
              "path": ["IchibaItem", "Search", "20260401"],
              "query": [
                { "key": "applicationId", "value": "{{APPLICATION_ID}}" },
                { "key": "keyword", "value": "ふるさと納税 牡蠣" },
                { "key": "hits", "value": "3" },
                { "key": "format", "value": "json" },
                { "key": "field", "value": "0" }
              ]
            },
            "description": "**実証で 4,533 件**。すべて `【ふるさと納税】` プレフィックス入りの正規返礼品。"
