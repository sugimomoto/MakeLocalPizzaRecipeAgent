              "raw": "{{BASE_URL}}/IchibaItem/Search/20260401?applicationId={{APPLICATION_ID}}&keyword=ふるさと納税 牡蠣&NGKeyword=訳あり&hits=10&format=json&field=0",
              "host": ["{{BASE_URL}}"],
