# Build/dist artifacts
node_modules
.next
out
build
dist
coverage
*.tsbuildinfo

# Source control / CI / Editor
.git
.github
.gitignore
.vscode
.idea
.DS_Store

# Docs / 設計 / Steering (本番イメージには不要)
docs
.steering
.claude
.devcontainer
design

# Web build context: agent/ は data/ingredients.yaml のみ必要なので、
# それ以外の重い path を除外する (src / scripts / tests / .venv 等)。
# infra / _reference / agent の Python 関連は image に含めない。
agent/src
agent/scripts
agent/tests
agent/.venv
agent/.mypy_cache
agent/.pytest_cache
agent/.ruff_cache
agent/.env
agent/uv.lock
agent/pyproject.toml
agent/Dockerfile
agent/.dockerignore
agent/README.md
agent/__pycache__
infra
_reference

# Test / Dev only
tests
playwright-report
test-results
*.log
firebase-debug.log
ui-debug.log
firestore-debug.log

# Env
# .env.production は Cloud Run build に使う NEXT_PUBLIC_FIREBASE_* を
# build 時 bundle に焼き込むため、image build context に含める
# (Firebase Web config は公開を前提とする設計のため commit 対象に含めて OK)。
.env
.env.local
.env.development
.env.test
!.env.example
!.env.production

# Python (Web Dockerfile では含めない)
__pycache__
.venv
venv
.pytest_cache
.ruff_cache
.mypy_cache

# Terraform
.terraform
*.tfstate
*.tfvars

# README / CLAUDE.md は image に含めない
README.md
CLAUDE.md
