# =============================================================================
# .env.example — Slice 2 時点のテンプレ
# =============================================================================
# Slice 2 で Python ADK Agent + Vertex Gemini 連動。
# AGENT_MODE で mock / http を切替 (オフライン開発は mock のまま)。
# =============================================================================

# ---- アプリ基本 -------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Make Local Pizza Recipe Agent"
NEXT_PUBLIC_APP_VERSION=0.5.0

# ---- Agent モード切替 (Web → Agent) ----------------------------------------
# mock: MockAgentClient (Slice 1 と同じ決定論的 3 案、Agent プロセス不要)
# http: HttpAgentClient → Python Agent (uvicorn) → Vertex Gemini
AGENT_MODE=mock
# Slice 4 で 8080 → 8001 に移行 (8080 は Firestore Emulator に明け渡し)
AGENT_BASE_URL=http://localhost:8001
AGENT_TIMEOUT_MS=60000

# ---- Agent 側 (Python / MLPR_ prefix で pydantic-settings が読む) ----------
# MLPR_GOOGLE_CLOUD_PROJECT=          # Vertex AI を呼ぶプロジェクト ID
# MLPR_VERTEX_AI_LOCATION=asia-northeast1
# MLPR_GEMINI_MODEL=gemini-2.5-flash
# MLPR_IMAGEN_MODEL=imagen-4.0-generate-001   # Slice 3 で追加 (詳細画面の画像生成)
# MLPR_USE_MOCK_LLM=false             # true で LLM 呼び出しをモックに置換 (オフライン dev)
# MLPR_USE_MOCK_IMAGE=false           # true で Imagen 呼び出しをモック (1x1 PNG) に置換
# MLPR_MAX_TIMEOUT_SEC=60
# MLPR_INGREDIENTS_YAML_PATH=data/ingredients.yaml

# ---- Firebase (Slice 4) ----------------------------------------------------
# Web 側 (Next.js): NEXT_PUBLIC_ prefix で client bundle に埋め込まれる
# Slice 4 はローカル Emulator のみ。本番プロジェクトの値は Slice 6 (デプロイ時) で設定。
NEXT_PUBLIC_FIREBASE_PROJECT_ID=mlpr-local
NEXT_PUBLIC_FIREBASE_API_KEY=fake-api-key-emulator
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=mlpr-local.firebaseapp.com
NEXT_PUBLIC_FIREBASE_APP_ID=1:0:web:0
# true で Auth/Firestore/Storage を Emulator に向ける (localhost:9099/8080/9199)
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true

# Python Agent 側: Imagen で生成した PNG を Storage に put する設定
# MLPR_USE_MOCK_STORAGE=true            # true で MockStorageClient (オフライン dev / CI)
# MLPR_FIREBASE_STORAGE_BUCKET=mlpr-local.appspot.com
# MLPR_FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199  # 未指定なら本番 GCS に接続

# ---- 楽天ふるさと納税 連動 (Slice 5) ---------------------------------------
# Slice 5 の機能 on/off スイッチ (Web / Python の両方を off にすると safe rollout)。
# off 既定で、機能が完成するまで本番影響ゼロ。
NEXT_PUBLIC_FURUSATO_INTEGRATION=off
# MLPR_FURUSATO_INTEGRATION=off

# Python Agent 側のオフライン開発 / CI 用モック。true で InMemoryFurusatoCache
# + dummy items を返す (実 API 不要)。
# MLPR_USE_MOCK_FURUSATO=false

# 楽天 Web Service 新エンドポイント用キー (refresh_furusato_cache.py が使う)。
# 取得方法: 楽天デベロッパー (https://webservice.rakuten.co.jp/) でアプリ申請
#   - applicationId は UUID 形式 (例: 'a1b2c3d4-...')
#   - accessKey は 'pk_' プレフィックス (新エンドポイント必須)
#   - affiliateId は任意 (指定すると affiliateUrl 付き)
# Slice 5 ではローカルの .env に直書き、Slice 6 で Secret Manager に移行予定。
# RAKUTEN_APPLICATION_ID=
# RAKUTEN_ACCESS_KEY=
# RAKUTEN_AFFILIATE_ID=

# ---- 観測 (Slice 6 で実装) -------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=
# LOG_LEVEL=info
