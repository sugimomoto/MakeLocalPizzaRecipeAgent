# =============================================================================
# .env.example — Slice 2 時点のテンプレ
# =============================================================================
# Slice 2 で Python ADK Agent + Vertex Gemini 連動。
# AGENT_MODE で mock / http を切替 (オフライン開発は mock のまま)。
# =============================================================================

# ---- アプリ基本 -------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Make Local Pizza Recipe Agent"
NEXT_PUBLIC_APP_VERSION=0.3.0

# ---- Agent モード切替 (Web → Agent) ----------------------------------------
# mock: MockAgentClient (Slice 1 と同じ決定論的 3 案、Agent プロセス不要)
# http: HttpAgentClient → Python Agent (uvicorn) → Vertex Gemini
AGENT_MODE=mock
# Slice 4 で 8080 → 8001 に移行 (8080 は Firestore Emulator に明け渡し)
AGENT_BASE_URL=http://localhost:8001
AGENT_TIMEOUT_MS=60000

# ---- Agent 側 (Python / MLPR_ prefix で pydantic-settings が読む) ----------
# MLPR_GOOGLE_CLOUD_PROJECT=          # Vertex AI を呼ぶプロジェクト ID
# MLPR_VERTEX_AI_LOCATION=asia-northeast1
# MLPR_GEMINI_MODEL=gemini-2.5-flash
# MLPR_IMAGEN_MODEL=imagen-4.0-generate-001   # Slice 3 で追加 (詳細画面の画像生成)
# MLPR_USE_MOCK_LLM=false             # true で LLM 呼び出しをモックに置換 (オフライン dev)
# MLPR_USE_MOCK_IMAGE=false           # true で Imagen 呼び出しをモック (1x1 PNG) に置換
# MLPR_MAX_TIMEOUT_SEC=60
# MLPR_INGREDIENTS_YAML_PATH=data/ingredients.yaml

# ---- Firebase (Slice 4 で実装) ---------------------------------------------
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=

# ---- 楽天 Web Service (Slice 5 で実装) -------------------------------------
# RAKUTEN_APPLICATION_ID=
# RAKUTEN_ACCESS_KEY=

# ---- 観測 (Slice 6 で実装) -------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=
# LOG_LEVEL=info
