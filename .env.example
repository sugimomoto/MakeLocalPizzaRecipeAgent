# =============================================================================
# .env.example — Slice 1 時点のテンプレ
# =============================================================================
# Slice 1 (本書) では外部 API 未連動。基本 BFF のみで完結。
# Slice 2 以降で AGENT_BASE_URL / GEMINI / Firebase / 楽天 を追加。
# =============================================================================

# ---- アプリ基本 -------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Make Local Pizza Recipe Agent"
NEXT_PUBLIC_APP_VERSION=0.1.0

# ---- Agent (Slice 2 で実装) -------------------------------------------------
# AGENT_BASE_URL=http://localhost:8080
# AGENT_TIMEOUT_MS=30000

# ---- Gemini / Vertex AI (Slice 2 で実装) -----------------------------------
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=asia-northeast1
# GEMINI_MODEL=gemini-2.5-flash

# ---- Firebase (Slice 4 で実装) ---------------------------------------------
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=

# ---- 楽天 Web Service (Slice 5 で実装) -------------------------------------
# RAKUTEN_APPLICATION_ID=
# RAKUTEN_ACCESS_KEY=

# ---- 観測 (Slice 6 で実装) -------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=
# LOG_LEVEL=info
