# =============================================================================
.claude/.DS_Store
.claude/scheduled_tasks.lock
.claude/projects/

# =============================================================================
# Node / pnpm / Next.js
# =============================================================================
node_modules/
.pnpm-store/
.next/
out/
build/
dist/
coverage/
*.tsbuildinfo
.swc/
next-env.d.ts

# =============================================================================
# Logs
# =============================================================================
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# 環境変数
# =============================================================================
.env
.env.*
!.env.example
!.env.*.example

# =============================================================================
# 生成データ (build 時に YAML から生成)
# =============================================================================
src/data/ingredients.generated.json

# =============================================================================
# Python (Slice 2 以降の agent/ 用)
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# =============================================================================
# Terraform (Slice 6 以降の infra/ 用)
# =============================================================================
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example

# =============================================================================
# E2E / Playwright
# =============================================================================
test-results/
playwright-report/
playwright/.cache/

# =============================================================================
