rules_version = '2';

// ふるさとピザ帳 (MakeLocalPizzaRecipeAgent) — Firestore Security Rules
//
// データモデル:
//   users/{uid}/savedRecipes/{candidateId}   - Slice 4 ピザ帳 (本人のみ R/W)
//   users/{uid}/drafts/{candidateId}         - Slice 7 フィードバック下書き (本人のみ R/W)
//   furusato_items/{ingredientId}            - Slice 5 楽天ふるさと納税キャッシュ
//                                              (public read / client write 不可)
//   rate_limits/{docId}                      - Slice 9 アプリ層レートリミット
//                                              (Admin SDK のみ R/W、client から完全 deny)
//   shared_recipes/{shareId}                 - Slice 10 共有レシピ snapshot
//                                              (public read / Admin SDK のみ write)
//   share_index/{indexKey}                   - Slice 10 べき等インデックス
//                                              (Admin SDK のみ R/W)
service cloud.firestore {
  match /databases/{database}/documents {
    // Slice 4: ピザ帳 (Slice 7 で feedback フィールドが追加されるが、
    // 同一 doc 内 merge save のためルール変更なし)
    match /users/{uid}/savedRecipes/{candidateId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Slice 7: フィードバック下書き (3 秒 debounce で自動保存)
    // 本人のみ R/W、未認証 / 他人は完全 deny。
    match /users/{uid}/drafts/{candidateId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Slice 5: 楽天ふるさと納税キャッシュ
    // 商品情報は公開データのため public read。書き込みは
    // refresh_furusato_cache.py の Admin SDK のみ (rules バイパス)。
    match /furusato_items/{ingredientId} {
      allow read: if true;
      allow write: if false;
    }

    // Slice 9: アプリ層レートリミット
    // server-side (Firebase Admin SDK) からのみ R/W。client からは完全 deny。
    // TTL ポリシー (expiresAt フィールド) で 2 時間後に自動削除される。
    match /rate_limits/{docId} {
      allow read, write: if false;
    }

    // Slice 10: 共有レシピ (公開閲覧 + べき等インデックス)
    // 書き込みは Admin SDK 経由のみ (POST /api/share)、誰でも read 可。
    match /shared_recipes/{shareId} {
      allow read: if true;
      allow write: if false;
    }
    // 同 owner + candidateId のべき等性ガード。Admin SDK のみ R/W。
    match /share_index/{indexKey} {
      allow read, write: if false;
    }

    // それ以外は明示的に deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
